{
  "name": "pr-slop-filter",
  "version": "1.0.0",
  "description": "Detect AI-generated slop PRs before they waste maintainers' time",
  "keywords": ["github", "ai", "pull-request", "slop", "ci", "code-quality"],
  "author": "Noxlie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxlie/pr-slop-filter"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pr-slop": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/github": "^6.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "octokit": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
